                "jsCode": "// UPDATE STATUS - HARDCODED FOR DEMO\nconst body = $input.item.json.body;\nconst id = body.id;\nconst status = body.status;\n\n// FORÇAR ABA DE HOJE PARA EVITAR ERROS\nconst sheetNameRes = \"Reservas_Quarta\";\nconst sheetNameMesas = \"Mesas_Quarta\";\n\nreturn { id, status, sheetNameRes, sheetNameMesas };"
            },
