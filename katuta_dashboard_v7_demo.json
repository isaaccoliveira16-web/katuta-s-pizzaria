        {
            "parameters": {
                "jsCode": "// CONFIG DEMO CLIENTE - FIXO PARA HOJE\nconst now = new Date();\nconst targetDate = new Date(now.getTime() - (3 * 60 * 60 * 1000)); // UTC-3 Fix\n\nconst isoDate = targetDate.toISOString().split('T')[0];\nconst daysMap = ['Domingo', 'Segunda', 'Terca', 'Quarta', 'Quinta', 'Sexta', 'Sabado'];\nlet dayName = daysMap[targetDate.getDay()];\nif (dayName === 'Segunda') dayName = 'Terca';\n\n// HARDCODED FOR STABILITY\nconst sheetNameRes = `Reservas_Quarta`;\nconst sheetNameMesas = `Mesas_Quarta`;\n\nreturn {\n  day_name: dayName,\n  target_day: dayName,\n  sheet_reservas: sheetNameRes,\n  sheet_mesas: sheetNameMesas,\n  date_formatted: targetDate.toLocaleDateString('pt-BR'),\n  iso_date: isoDate\n};"
            },
            "id": "node-config-dates",
            "name": "[JS] Configurar Datas",
            "type": "n8n-nodes-base.code",
            "typeVersion": 1,
            "position": [
                700,
                400
            ]
        },
        {
            "parameters": {
                "operation": "read",
                "documentId": "1LyDrtgOdh9hfEEcZso3r-Bzg5J8XtL1306fsURMK4hk",
